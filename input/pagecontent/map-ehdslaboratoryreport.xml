          </a>
        </li>
        <li>
          <strong>Target FHIR profile:</strong>
          <a href="StructureDefinition-Bundle-eu-lab.html">BundleLabReportEu</a>
        </li>
        <li>
          <strong>Target FHIR profile:</strong>
          <a href="StructureDefinition-Composition-eu-lab.html">CompositionLabReportEu</a>
        </li>
        <li>
          <strong>Target FHIR profile:</strong>
          <a href="StructureDefinition-DiagnosticReport-eu-lab.html">DiagnosticReportLabEu</a>
        </li>
      </ul>
    </div>

